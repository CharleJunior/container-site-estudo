# Configurações Gerais do Django
SECRET_KEY=sua_chave_secreta_aqui
DEBUG=True
ALLOWED_HOSTS=testeseguranca.pythonanywhere.com,127.0.0.1,localhost:8000, localhost


# Configuração de E-mail
EMAIL_HOST_PASSWORD=sua_senha_de_aplicativo_do_email_aqui

# Banco de Dados PostgreSQL (Configuração padrão para o Docker)
PG_NAME=nomde do seu banco
PG_USER=nome do seu usuario postgres
PG_PASS=sua_senha_do_banco_aqui
PG_HOST=host.docker.internal
PG_PORT=5432

# (Opcional) Banco de Dados MySQL caso queira deixar mapeado
# DB_NAME=banco-sistema
# DB_USER=root
# DB_PASS=
# DB_HOST=localhost